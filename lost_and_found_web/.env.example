SECRET_KEY=change-this-in-production
BACKEND_PUBLIC_URL=http://127.0.0.1:5000
PORT=5000
DATABASE_PATH=
UPLOAD_FOLDER=
MAX_UPLOAD_MB=8
GOOGLE_CLIENT_ID=
STORAGE_PROVIDER=local
# Cloudinary (required only when STORAGE_PROVIDER=cloudinary)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=lost_and_found
# AWS S3 (required only when STORAGE_PROVIDER=s3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
S3_BUCKET_NAME=
S3_KEY_PREFIX=lost-and-found
EMAIL_NOTIFIER_PROVIDER=stdout
EMAIL_NOTIFIER_FROM=no-reply@lostfound.local
EMAIL_NOTIFIER_SMTP_HOST=
EMAIL_NOTIFIER_SMTP_PORT=587
EMAIL_NOTIFIER_SMTP_USER=
EMAIL_NOTIFIER_SMTP_PASSWORD=
EMAIL_NOTIFIER_USE_TLS=true
OTP_CODE_TTL_SECONDS=600
OTP_REQUEST_COOLDOWN_SECONDS=60
OTP_MAX_VERIFY_ATTEMPTS=5
RATE_LIMIT_AUTH_WINDOW_SECONDS=900
RATE_LIMIT_AUTH_MAX_ATTEMPTS=12
RATE_LIMIT_ITEMS_WINDOW_SECONDS=3600
RATE_LIMIT_ITEMS_MAX_ATTEMPTS=120
